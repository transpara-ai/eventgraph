<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>LovYou.EventGraph.Postgres</PackageId>
    <Version>0.2.0</Version>
    <Authors>LovYou AI</Authors>
    <Description>PostgreSQL store for EventGraph</Description>
    <PackageTags>eventgraph;postgres;postgresql;event-sourcing</PackageTags>
    <RepositoryUrl>https://github.com/lovyou-ai/eventgraph</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EventGraph\EventGraph.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql" Version="9.0.3" />
  </ItemGroup>

</Project>

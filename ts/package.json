{
  "name": "@lovyou-ai/eventgraph",
  "version": "0.3.0",
  "description": "Hash-chained, append-only, causal event graph",
  "main": "dist/index.js",
  "bin": {
    "eg": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eventgraph",
    "event-sourcing",
    "hash-chain",
    "causal-graph"
  ],
  "license": "BSL-1.1",
  "author": "LovYou AI <matt@lovyou.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/lovyou-ai/eventgraph.git",
    "directory": "ts"
  },
  "homepage": "https://github.com/lovyou-ai/eventgraph",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
